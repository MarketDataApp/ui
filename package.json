{
  "name": "@marketdataapp/ui",
  "version": "1.2.0",
  "description": "Shared UI preset and theme utilities for MarketData properties",
  "main": "preset.js",
  "license": "UNLICENSED",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/MarketDataApp/ui.git"
  },
  "exports": {
    "./preset": "./preset.js",
    "./theme": "./theme.js",
    "./css/components": "./css/components.css"
  },
  "scripts": {
    "build": "npm run build:css",
    "build:css": "tailwindcss -i css/components.input.css -o css/components.css --config tailwind.build.config.js",
    "dev": "concurrently -n css,serve -c blue,green \"npm:dev:css\" \"npm:dev:serve\"",
    "dev:css": "tailwindcss -i css/components.input.css -o css/components.css --config tailwind.build.config.js --watch",
    "dev:serve": "serve . -p 3000",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "npm run build",
    "test": "vitest run"
  },
  "peerDependencies": {
    "tailwindcss": ">=3.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "serve": "^14.2.5",
    "tailwindcss": "^3.4.19",
    "vitest": "^2.0.0"
  }
}
