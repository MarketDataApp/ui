{
  "name": "@marketdataapp/ui",
  "version": "2.7.0",
  "description": "Shared UI theme and component styles for MarketData properties",
  "license": "UNLICENSED",
  "type": "module",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/MarketDataApp/ui.git"
  },
  "exports": {
    "./theme": "./theme.js",
    "./css/components": "./css/components.css",
    "./css/components.no-reset": "./css/components.no-reset.css",
    "./css/components.src": "./css/components.src.css",
    "./css/theme": "./css/theme.css",
    "./navbar-overflow": "./navbar-overflow.js",
    "./user-profile": "./user-profile.js",
    "./theme-toggle": "./theme-toggle.js"
  },
  "scripts": {
    "build": "npm run build:css",
    "build:css": "tailwindcss -i css/components.input.css -o css/components.css && tailwindcss -i css/components.no-reset.input.css -o css/components.no-reset.css && node scripts/unlayer.js",
    "dev": "concurrently -n css,serve -c blue,green \"npm:dev:css\" \"npm:dev:serve\"",
    "dev:css": "tailwindcss -i css/components.input.css -o css/components.css --watch",
    "dev:serve": "serve . -p 3000",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky || true",
    "test": "vitest run",
    "test:e2e": "set -a && source .env && set +a && npx playwright test"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/cli": "^4.2.1",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "serve": "^14.2.5",
    "vitest": "^2.0.0"
  }
}
